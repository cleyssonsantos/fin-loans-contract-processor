# ============================================================
# fin-loans-contract-processor — Environment Variables
# Copie para .env e preencha os valores
# NUNCA commite o .env com valores reais
# ============================================================

# App
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://loans_user:loans_pass@postgres:5432/loans_db

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP_ID=loans-consumer-group

# Auth JWT RS256
# Em produção, usar caminhos para arquivos ou secrets manager
JWT_PRIVATE_KEY_PATH=./secrets/private.pem
JWT_PUBLIC_KEY_PATH=./secrets/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT_EXPIRY_WARNING_THRESHOLD_SECONDS=300

# Criptografia AES-256 (dados sensíveis do borrower)
# Em produção, usar AWS Secrets Manager / Vault
ENCRYPTION_KEY=change-me-32-bytes-key-here-prod!

# Redis / Rate limiting
REDIS_URL=redis://redis:6379
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=fin-loans-contract-processor
